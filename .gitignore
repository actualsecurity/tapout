# =============================================================================
# Secrets & signing keys -- NEVER commit these.
# The PRIVATE OTA signing key lives only in the GH Actions secret OTA_SIGNING_KEY.
# =============================================================================
private_key.pem
ci_pub.pem
*.pem
# ...but the PUBLIC key is intentionally tracked (it is not a secret):
!public_key.pem

# Provisioning / secret config (real secrets live in NVS, never in the image):
secrets.h
config.h
tapout/secrets.h
tapout/config.h

